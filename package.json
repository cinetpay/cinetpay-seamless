{
  "name": "cinetpay-seamless",
  "version": "0.1.0",
  "description": "CinetPay Seamless — inline payment modal for web applications. No redirect, no iframe. Works with any framework.",
  "type": "module",
  "main": "./dist/cinetpay-seamless.umd.js",
  "module": "./dist/cinetpay-seamless.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/cinetpay-seamless.js"
      },
      "require": {
        "default": "./dist/cinetpay-seamless.umd.js"
      }
    },
    "./style.css": "./dist/cinetpay-seamless.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cinetpay",
    "payment",
    "seamless",
    "checkout",
    "mobile-money",
    "africa",
    "inline",
    "modal"
  ],
  "author": "CinetPay",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
